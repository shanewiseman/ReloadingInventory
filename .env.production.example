# Copy to .env.production and replace these values before deploying.

STORAGE_SECRET_KEY=replace-with-a-long-random-storage-secret
RENDERER_SECRET_KEY=replace-with-a-different-long-random-renderer-secret
PUBLIC_BASE_URL=https://reload.example.com
RELOAD_LEDGER_HOST=reload.example.com

# Traefik / Authentik routing. These match the common stack shown in your other
# services and can be changed to match your server.
DMZ_NETWORK=dmz_internal
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=myresolver
AUTHENTIK_MIDDLEWARE=authentik@docker

# Persistent SQLite database, uploaded files, and backups.
RELOAD_LEDGER_DATA_DIR=/mnt/docker_data/dmz/reload-ledger/data

SESSION_HOURS=12
SESSION_COOKIE_SECURE=true
LOCAL_RESET_ENABLED=true
